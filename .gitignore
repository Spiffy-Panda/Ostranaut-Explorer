# Game data — not redistributable. See README for setup instructions.
/data/
/data.original/
/decomp/

# Note: comment_mod/ IS tracked. It holds our schema improvements that get
# overlaid onto data/ at setup time, anticipating the v2 mod-overlay loader.

# Scratch / exploratory scripts (per CLAUDE.md convention)
/scrap_*/

# Test mod data — local modding experiments, not redistributable
/testdata_mods/

# Wiki page cache — fetch-once, re-read locally. See CLAUDE.md.
/wiki_cache/

# Build outputs
/build/
/build-public/
**/bin/
**/obj/

# Rendered user-stories live alongside the site source so that previewing
# src/Ostranauts.Site/index.html directly via file:// resolves the User
# Stories tab card. Generated by utils/python/render_user_stories.py at
# build time; regenerate rather than tracking the rendered HTML.
/src/Ostranauts.Site/user-stories/

# Node (when the site frontend gets one)
**/node_modules/

# IDE / editor
/.vscode/
/.idea/
*.user
*.suo
.vs/

# Claude Code per-user settings (a shared .claude/settings.json would be tracked).
# .claude/launch.json IS tracked — preview-server config is shared dev tooling.
# .claude/skills/ holds per-user skill registrations (managed by Claude Code).
.claude/settings.local.json
.claude/skills/

# Per-user local override of CLAUDE.md (machine paths, toolchain quirks).
# CLAUDE.md is shared; CLAUDE.local.md is the local-only sibling.
CLAUDE.local.md

# Per-session retrospective notes the skill-extraction skill writes here.
# Each is a one-off reflection — keep them out of the repo to avoid noise.
/skill-extractions/

# Playwright MCP working directory — per-session snapshots and console
# captures used for visual verification. Not redistributable.
/.playwright-mcp/

# Verbatim Discord chat exports kept locally for context. Not redistributable
# (factor 3 of the fair-use check in CLAUDE.md). See CLAUDE.local.md for the
# folder contents and "paraphrase, don't paste" usage rule.
/prose-extraction/Discord/

# Designer-handoff archives. We unpack them into per-handoff folders (kept
# only on the design branches that integrate them) and the zip is redundant
# once extracted.
/notes/*.zip

# OS
.DS_Store
Thumbs.db
